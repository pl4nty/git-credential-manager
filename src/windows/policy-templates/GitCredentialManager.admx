      <supportedOn ref="SUPPORTED_GCM"/>
      <elements>
        <enum id="GCM_Interactive_Enum" valueName="interactive">
          <item displayName="$(string.GCM_Interactive_auto)">
            <value>
              <string>auto</string>
            </value>
          </item>
          <item displayName="$(string.GCM_Interactive_true)">
            <value>
              <string>true</string>
            </value>
          </item>
          <item displayName="$(string.GCM_Interactive_false)">
            <value>
              <string>false</string>
            </value>
          </item>
        </enum>
      </elements>
    </policy>
